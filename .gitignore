# ──────────────────────────────
# Aegis: The Cognitive Scam Firewall
# Master .gitignore
# ──────────────────────────────

# ──────────────────────────────
# Python / FastAPI
# ──────────────────────────────

# Virtual environment
venv/
.venv/
env/
ENV/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Environment variables — real secrets
.env
.env.*
!.env.example   # safe placeholder — committed intentionally
!.env.template  # safe placeholder — committed intentionally

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Unit test / coverage
.coverage
htmlcov/
.pytest_cache/

# mypy / type checkers
.mypy_cache/
.ruff_cache/

# Jupyter Notebooks
.ipynb_checkpoints/

# ──────────────────────────────
# Database & Cache
# ──────────────────────────────
*.db
*.sqlite
*.sqlite3

# Alembic auto-generated migration files (keep schema.py, not version files in CI)
# alembic/versions/          # Uncomment if you don't want to commit migrations

# ──────────────────────────────
# Logs & Runtime Artefacts
# ──────────────────────────────
*.log
logs/
*.tmp
*.bak
*.swp
*.swo

# ──────────────────────────────
# Flutter / Android / Dart
# ──────────────────────────────

.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart
*.config.dart

# Android
frontend/android/.gradle/
frontend/android/app/debug/
frontend/android/app/profile/
frontend/android/app/release/
*.apk
*.aab
*.jks
*.keystore
local.properties

# iOS (if applicable in the future)
frontend/ios/Pods/
frontend/ios/.symlinks/

# ──────────────────────────────
# IDE / Editor
# ──────────────────────────────

# IntelliJ / Android Studio
.idea/
*.iml
*.ipr
*.iws

# VS Code
.vscode/
*.code-workspace

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
