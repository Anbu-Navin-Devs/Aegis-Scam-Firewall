# ════════════════════════════════════════════════════════════
# Aegis Backend — Environment Variable Template
# ════════════════════════════════════════════════════════════
#
# SETUP INSTRUCTIONS (first-time):
#   1. Copy this file:  cp .env.example .env
#   2. Fill in EVERY value marked ← REQUIRED
#   3. Never commit the .env file — it is already in .gitignore
#
# ════════════════════════════════════════════════════════════


# ── Google Gemini AI ─────────────────────────────────────────
# Obtain your key at https://aistudio.google.com/app/apikey
# The key starts with "AIza..."
GEMINI_API_KEY=your-gemini-api-key-here          # ← REQUIRED


# ── PostgreSQL Database ──────────────────────────────────────
# MUST use the postgresql+asyncpg:// scheme (not plain postgresql://)
# The asyncpg driver is required for SQLAlchemy 2.x async support.
#
# Format:
#   postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
#
# Local dev example (default):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aegis   # ← REQUIRED

# Cloud / hosted example (e.g. Supabase, Railway, Render):
# DATABASE_URL=postgresql+asyncpg://user:pass@db.supabase.co:5432/postgres


# ── Application Config ───────────────────────────────────────
# These have safe defaults — override only if needed.
ENV=development        # 'development' | 'production'
DEBUG=true             # Set to false in production (disables SQL echo)


# ── (Future / Optional) ─────────────────────────────────────
# Uncomment when Redis / JWT auth are implemented.
# REDIS_URL=redis://localhost:6379/0
# SECRET_KEY=change-me-to-a-random-32-char-string-in-production
# ACCESS_TOKEN_EXPIRE_MINUTES=30
